#!/usr/bin/env bash

set -euo pipefail

state_dir="${CODA_TEST_STATE_DIR:?CODA_TEST_STATE_DIR is required}"
sessions_file="$state_dir/tmux-sessions"
actions_file="$state_dir/tmux-actions"
env_file="$state_dir/tmux-env"

mkdir -p "$state_dir"
touch "$sessions_file" "$actions_file" "$env_file"

log_action() {
    printf '%s\n' "$*" >> "$actions_file"
}

has_session() {
    local target="$1"
    grep -Fx -- "$target" "$sessions_file" >/dev/null 2>&1
}

add_session() {
    local target="$1"
    if ! has_session "$target"; then
        printf '%s\n' "$target" >> "$sessions_file"
    fi
}

remove_session() {
    local target="$1"
    local tmp
    tmp=$(mktemp)
    grep -Fvx -- "$target" "$sessions_file" > "$tmp" || true
    mv "$tmp" "$sessions_file"
}

list_sessions() {
    local format="#{session_name}"

    if [ "${1:-}" = "-F" ]; then
        format="$2"
    fi

    while IFS= read -r session; do
        [ -n "$session" ] || continue
        case "$format" in
            '#{session_name}')
                printf '%s\n' "$session"
                ;;
            '#{session_name}  (#{session_windows}w, created #{t:session_created})')
                printf '%s  (1w, created stub)\n' "$session"
                ;;
            *)
                printf '%s\n' "$session"
                ;;
        esac
    done < "$sessions_file"
}

command_name="${1:-}"
shift || true

case "$command_name" in
    has-session)
        [ "$1" = "-t" ] || exit 1
        if has_session "$2"; then
            exit 0
        fi
        exit 1
        ;;
    new-session)
        local_session=""
        while [ $# -gt 0 ]; do
            case "$1" in
                -s)
                    local_session="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        [ -n "$local_session" ] || exit 1
        add_session "$local_session"
        log_action "new-session:$local_session"
        ;;
    new-window)
        local_session=""
        while [ $# -gt 0 ]; do
            case "$1" in
                -t)
                    local_session="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done
        [ -n "$local_session" ] || exit 1
        add_session "$local_session"
        log_action "new-window:$local_session"
        ;;
    set-environment)
        [ "$1" = "-t" ] || exit 1
        printf '%s|%s|%s\n' "$2" "$3" "$4" >> "$env_file"
        log_action "set-environment:$2:$3=$4"
        ;;
    attach)
        [ "$1" = "-t" ] || exit 1
        log_action "attach:$2"
        ;;
    switch-client)
        [ "$1" = "-t" ] || exit 1
        log_action "switch-client:$2"
        ;;
    kill-session)
        [ "$1" = "-t" ] || exit 1
        remove_session "$2"
        log_action "kill-session:$2"
        ;;
    list-sessions)
        list_sessions "$@"
        ;;
    set-option|select-pane|split-window|display-message|capture-pane)
        log_action "$command_name:$*"
        ;;
    show-environment)
        [ "$1" = "-t" ] || exit 1
        target="$2"
        key="$3"
        awk -F'|' -v target="$target" -v key="$key" '$1 == target && $2 == key { value=$3 } END { if (value != "") print key "=" value; else exit 1 }' "$env_file"
        ;;
    *)
        log_action "unhandled:$command_name $*"
        ;;
esac
