# Coda Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- Directories ---

# Where your project repositories live
PROJECTS_DIR="$HOME/projects"

# --- tmux ---

# Prefix for coda tmux session names
SESSION_PREFIX="coda-"

# --- Git ---

# Default branch name for new worktrees
DEFAULT_BRANCH="main"

# Git remote name
GIT_REMOTE="origin"

# --- OpenCode ---

# Use Vim for OpenCode's external editor flows (`/editor`, `/export`).
EDITOR="vim"
VISUAL="vim"

# Starting port for OpenCode serve instances (increments per session)
OPENCODE_BASE_PORT=4096

# Max port range (base + range = highest port)
OPENCODE_PORT_RANGE=10

# Default permission mode for headless sessions
# Options: '{"*":"allow"}' (autonomous) or '{}' (ask for everything)
OPENCODE_HEADLESS_PERMISSION='{"*":"allow"}'

# Provider mode for `coda auth`: claude-auth (default) or cliproxyapi
CODA_PROVIDER_MODE="claude-auth"

# CLIProxyAPI OpenAI-compatible base URL used for OpenCode provider config
CLIPROXYAPI_BASE_URL="http://localhost:8317/v1"

# Optional proxy API key used for model discovery/status probes and written into
# the managed OpenCode provider block when set
CLIPROXYAPI_API_KEY=""

# Optional health endpoint for `coda provider status`
CLIPROXYAPI_HEALTH_URL=""

# Optional override for the managed OpenCode config path
CODA_OPENCODE_CONFIG_PATH=""

# --- Node.js ---

# Node.js major version to install
NODE_MAJOR_VERSION=20

# Package manager preference: npm, pnpm, or yarn
PACKAGE_MANAGER="npm"

# --- Watcher (coda watch) ---

# How often to poll sessions for state changes (seconds)
CODA_WATCH_INTERVAL=5

# Minimum seconds between repeat notifications for the same pane
CODA_WATCH_COOLDOWN=60

# --- Layout & Profiles ---

# Default tmux layout when creating sessions (see: coda layout ls)
# Options: default, wide-twopane, classic, three-pane, four-pane
DEFAULT_LAYOUT="four-pane"

# Default Neovim config name (maps to ~/.config/<name>/)
# Use NVIM_APPNAME to run different nvim configs side-by-side
DEFAULT_NVIM_APPNAME="nvim"

# Where user layout scripts live (override built-ins of the same name)
CODA_LAYOUTS_DIR="$HOME/.config/coda/layouts"

# Where user profile overrides live
CODA_PROFILES_DIR="$HOME/.config/coda/profiles"

# --- Remote Access ---

# Set to "true" to auto-attach tmux on SSH login
AUTO_ATTACH_TMUX="true"

# Default tmux session name for auto-attach
DEFAULT_TMUX_SESSION="default"
